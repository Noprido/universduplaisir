<%- include('../layouts/header') %>

<%- include('../layouts/navigation') %>
<%- include('../layouts/mobileMenu') %>

<!-- ═══════════ EVENTS ═══════════ -->
<div id="page-events" >
  <div class="page-hero">
    <div class="section-label">Agenda</div>
    <h1 class="section-title">Nos <em>événements</em></h1>
    <p class="section-sub">Dates, heures et descriptions disponibles pour tous. L'adresse est réservée aux membres titulaires d'un pass.</p>
  </div>
  <section style="padding-top:3rem;">
    <div class="events-grid">
      <% events.forEach(event => { %>
      <div class="event-card">
        <div class="event-date-block">
          <div class="event-day"><%= event.jour %></div>
          <div class="event-month"><%= event.mois %></div>
        </div>
        <div>
          <div class="event-theme"><%= event.theme %></div>
          <div class="event-name"><%= event.nom %></div>
          <p class="event-desc"><%= event.description %></p>
          <div class="event-meta">
            <div class="event-meta-item"><span class="icon">◷</span> <%= event.heureDebut %> — <%= event.heureFin %></div>
            <div class="event-meta-item"><span class="icon">◈</span> <%= event.type %></div>
          </div>
          <% if(user) { %>
            <div class="event-address-box" style="margin-top:.8rem;">
              <div class="event-address-label">📍 Adresse</div>
              <div class="event-address-text"><%= event.adresse %><br>
                <span style="font-size:.72rem;color:var(--or);"><%= event.acces %></span>
              </div>
            </div>
          <% } else { %>
            <div class="event-locked">🔒 Adresse réservée aux membres</div>
          <% } %>
        </div>
      </div>
      <% }) %>
    </div>
    <% if(!user) { %>
    <div style="text-align:center;margin-top:3rem;padding-top:2.5rem;border-top:.5px solid var(--glass-border);">
      <p style="color:var(--ivoire-muted);font-size:.83rem;margin-bottom:1.3rem;">Souhaitez-vous obtenir les adresses et rejoindre le club ?</p>
      <button class="btn-primary" onclick="(location.assign('/auth/register'))">Demander mon inscription</button>
    </div>
    <% } %>
  </section>
  <footer><div class="footer-bottom" style="border-top:none;"><div class="footer-copy">© 2025 Univers du Plaisir</div><div class="footer-18">+18 uniquement</div></div></footer>
</div>

<%- include('../layouts/footer') %>