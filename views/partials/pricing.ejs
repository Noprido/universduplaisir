 <!-- FORMULES -->
  <section class="formules-section">
    <div class="section-label">Nos offres</div>
    <h2 class="section-title">Choisissez votre <em>pass</em></h2>
    <p class="section-sub">Abonnement mensuel. Votre pass est délivré par mail avec toutes les informations, incluant le lieu de l'événement.</p>
    <div class="formules-grid">
      <div class="formule-card">
        <div class="formule-icon">🎭</div>
        <div class="formule-name">Standard</div>
        <div class="formule-price">70€</div>
        <div class="formule-period">1 mois</div>
        <ul class="formule-features">
          <li>1 Plans cul gratuit par semaine</li>
          <li>Accès aux événements classiques</li>
          <li>Profil membre personnel</li>
          <li>Identifiant membre unique</li>
          <li>Adresse des lieux sur le pass</li>
        </ul>
        <button class="btn-outline btn-full" onclick="(location.assign('/auth/register'))">Demander ce pass</button>
      </div>
      <div class="formule-card featured">
        <div class="formule-badge">Le plus choisi</div>
        <div class="formule-icon">💎</div>
        <div class="formule-name">Premium</div>
        <div class="formule-price">100€</div>
        <div class="formule-period">2 mois</div>
        <ul class="formule-features">
          <li>2 Plans cul gratuit par semaine</li>
          <li>Accès à tous les événements</li>
          <li>Priorité de réservation</li>
          <li>Profil membre amélioré</li>
          <li>Invitations anticipées</li>
        </ul>
        <button class="btn-primary btn-full" onclick="(location.assign('/auth/register'))">Demander ce pass</button>
      </div>
      <div class="formule-card">
        <div class="formule-icon">👑</div>
        <div class="formule-name">VIP</div>
        <div class="formule-price">150€</div>
        <div class="formule-period">4 mois</div>
        <ul class="formule-features">
          <li>5 Plans cul gratuit par semaine</li>
          <li>Accès privilégié à tout</li>
          <li>Invitations soirées spéciales</li>
          <li>Espace VIP exclusif</li>
          <li>Service personnalisé</li>
        </ul>
        <button class="btn-rose btn-full" onclick="(location.assign('/auth/register'))">Demander ce pass</button>
      </div>
    </div>
  </section>
